# Ignore python virtual environments anywhere in the workspace
**/.venv/
**/venv/

secret.json
venv/
.venv/
**/__pycache__/
*.pyc

# --- Inspecta Data Storage ---
# We ignore the entire Data folder so videos and audio are never pushed
Data/
documentation/
CompanyStorage*/
uploads/
processed/

# Exclude Node/Frontend build dependencies and builds
**/node_modules/
**/.next/
**/out/
**/.tsconfig.tsbuildinfo

# Exclude Git and IDE settings
.git/
.github/
.vscode/
.idea/

# --- Audio Agent Specifics ---
# Ignore raw audio extractions
*.mp3
*.wav
*.mp4

# --- System Files ---
.DS_Store
Thumbs.db

# Optional: Ignore other heavy build or lock files
**/dist/
**/build/
**/.git/
*.log